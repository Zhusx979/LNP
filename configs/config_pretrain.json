{
  "model": {
    "model_name": "qwen/Qwen-1_8B",
    "max_seq_length": 256,
    "torch_dtype": "float16",
    "device_map": "auto"
  },
  "data": {
    "csv_paths": [
      "data/test_lipids.csv"
    ],
    "validation_split": 0.15,
    "batch_size": 1,
    "num_workers": 0,
    "deduplicate": false
  },
  "training": {
    "num_epochs": 1,
    "learning_rate": 5e-5,
    "weight_decay": 0.01,
    "warmup_steps": 100,
    "gradient_accumulation_steps": 4,
    "max_grad_norm": 1.0,
    "eval_steps": 500,
    "save_steps": 500,
    "logging_steps": 50,
    "seed": 42
  },
  "optimization": {
    "mixed_precision": "none",
    "gradient_checkpointing": true,
    "use_amp": false,
    "use_grad_scaler": false
  },
  "paths": {
    "output_dir": "models/qwen_1.8b_smiles_pretrained",
    "logs_dir": "logs",
    "tokenizer_path": "models/qwen_1.8b_smiles_pretrained/tokenizer.json",
    "model_cache_dir": "models/cache/qwen-1.8b"
  }
}
